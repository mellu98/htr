# Generated content is now committed so Render can serve it without running
# the analyzer on every deploy.
# /content/generated/

# But never commit extracted audio/frames (large binary/cache files).
/content/generated/*/assets/

# MP4 videos are NOT committed: GitHub rejects files >100MB.
# Videos are uploaded to Render persistent disk via admin upload
# (see plan: deploy-videos strategy).
/public/videos/*.mp4
/public/videos/**/*.mp4
