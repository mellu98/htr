# Wave Up — environment template. Copy to .env and fill in real values.

# ─── Database ───────────────────────────────────────────────────────────────
# Production is PostgreSQL (Render managed db "wave-up-db"). Schema.prisma is
# locked to postgresql. For local dev run Postgres via Docker:
#   docker run --name waveup-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgres:16
# Or use a hosted free tier (Neon / Supabase) and paste the URL here.
DATABASE_URL="postgresql://postgres:dev@localhost:5432/waveup"

# ─── MiniMax M3 (the "intelligence" model) ───────────────────────────────
# The multimodal M3 lives on OpenRouter. The api.minimax.io hosted endpoint
# exposes a text-only M3, so we default to OpenRouter to get text+image+video.
#
# Get a key at https://openrouter.ai/keys (any plan with a few dollars credit).
#
# Required for any real call. Leave empty to run fully on mock outputs.
MINIMAX_API_KEY=""

# Optional — defaults shown.
MINIMAX_MODEL="minimax/minimax-m3"
MINIMAX_BASE_URL="https://openrouter.ai/api/v1"

# ─── ASR model (audio → verbatim Italian transcript) ─────────────────────
# M3 is text+image+video only, not audio. We use Gemini Flash Lite for
# the ASR step — cheap, fast, excellent Italian.
MINIMAX_TRANSCRIBE_MODEL="google/gemini-2.5-flash-lite"

# ─── Local tooling ───────────────────────────────────────────────────────
# ffmpeg path (only needed if not on PATH). The repo assumes the yt-dlp
# winget install on Windows; override here for macOS / Linux.
# FFMPEG_PATH="/usr/local/bin/ffmpeg"

# Public app URL (used for absolute links in exports)
NEXT_PUBLIC_APP_URL="http://localhost:3000"