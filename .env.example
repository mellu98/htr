# SQLite database URL (default points to prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Optional — leave empty to run with mock AI outputs.
# When set, the AI pipeline will call the real model.
MINIMAX_API_KEY=""
MINIMAX_MODEL="MiniMax-M3"

# Public app URL (used for absolute links in exports)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
