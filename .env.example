# SQLite database URL (default points to prisma/dev.db)
DATABASE_URL="file:./dev.db"

# MiniMax M3 — leave empty to run with deterministic mock AI outputs.
# When MINIMAX_API_KEY is set, the AI pipeline calls the real model.
#
# Required:
MINIMAX_API_KEY=""

# Optional — defaults to MiniMax-M3.
MINIMAX_MODEL="MiniMax-M3"

# Optional — defaults to https://api.minimax.io/v1 (OpenAI-compatible).
# Override this to point at a local proxy, Azure OpenAI, or any
# OpenAI-compatible endpoint (e.g. https://api.openai.com/v1).
# MINIMAX_BASE_URL="https://api.minimax.io/v1"

# Public app URL (used for absolute links in exports)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
