// Wave Up — Prisma schema
// Adds the Wave Up product layer on top of HTR Training course engine.
// All Wave Up tables live alongside the original course tables; existing
// data is untouched.

generator client {
  provider = "prisma-client-js"
}

// Postgres for production (Render) and dev. Set DATABASE_URL accordingly:
//   - dev: postgresql://user:pass@localhost:5432/waveup
//   - prod (Render): injected automatically from the linked database
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// HTR Training — course engine (unchanged)
// ===========================================================================

model LessonProgress {
  id               String   @id @default(cuid())
  courseId         String
  lessonId         String
  lessonSlug       String
  watchedSeconds   Int      @default(0)
  videoPercent     Int      @default(0)
  completed        Boolean  @default(false)
  applied          Boolean  @default(false)
  lastWatchedAt    DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([courseId, lessonId])
  @@index([courseId, lessonSlug])
}

model Note {
  id         String   @id @default(cuid())
  courseId   String
  lessonId   String
  lessonSlug String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([courseId, lessonId])
}

model Bookmark {
  id         String   @id @default(cuid())
  courseId   String
  lessonId   String
  lessonSlug String
  title      String
  note       String?
  videoTime  Int?
  createdAt  DateTime @default(now())

  @@index([courseId, lessonId])
}

model ChecklistProgress {
  id          String    @id @default(cuid())
  courseId    String
  lessonId    String
  lessonSlug  String
  itemId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([courseId, lessonId, itemId])
  @@index([courseId, lessonSlug])
}

model FlashcardProgress {
  id         String   @id @default(cuid())
  courseId   String
  lessonId   String
  lessonSlug String
  cardId     String
  status     String   @default("unknown")
  updatedAt  DateTime @updatedAt

  @@unique([courseId, lessonId, cardId])
  @@index([courseId, lessonSlug])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  courseId       String
  lessonId       String
  lessonSlug     String
  score          Int
  totalQuestions Int
  correctAnswers Int
  answers        String
  createdAt      DateTime @default(now())

  @@index([courseId, lessonSlug])
}

model ReviewStatus {
  id            String   @id @default(cuid())
  courseId      String
  lessonId      String
  lessonSlug    String
  status        String   @default("pending")
  notes         String?
  reviewerNotes String?
  updatedAt     DateTime @updatedAt

  @@unique([courseId, lessonId])
  @@index([courseId, lessonSlug])
}

model AppSettings {
  id             String   @id @default("singleton")
  theme          String   @default("dark")
  preferredModel String?
  activeArtistId String?
  updatedAt      DateTime @updatedAt
}

// ===========================================================================
// Wave Up — product layer
// ===========================================================================

/// Artist profile — single source of truth for the artist being coached.
/// There's at most one "primary" artist per install, but managers may have
/// many ManagerArtist entries that reference a profile.
model ArtistProfile {
  id               String   @id @default(cuid())
  artistName       String
  musicGenre       String?
  currentLevel     String?  // emerging | growing | established
  mainGoal         String?
  targetAudience   String?
  nextReleaseDate  DateTime?
  activePlatforms  String?  // JSON: ["instagram","spotify","tiktok",…]
  biggestBlock     String?
  brandKeywords    String?  // comma-separated or JSON
  referenceArtists String?
  notes            String?
  // Operational metadata
  weeklyCallDay    String?  // "monday" … "sunday" — when the human call happens
  nextCallAt       DateTime?
  // Course linkage
  courseId         String   @default("htr-training")
  startedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  managerArtists      ManagerArtist[]
  tasks              Task[]
  callPrepReports    CallPrepReport[]
  coachConversations CoachConversation[]
  releases           Release[]
  contentIdeas       ContentIdea[]
  metricSnapshots    MetricSnapshot[]
  contacts           Contact[]
  outreach           Outreach[]
  goals              Goal[]

  @@index([courseId])
}

/// When the user is a manager, they can track multiple artists.
/// Each ManagerArtist is a lightweight "card" that points back to an
/// ArtistProfile (so a profile can exist without a manager relationship).
model ManagerArtist {
  id               String   @id @default(cuid())
  artistProfileId  String
  nickname         String?  // how the manager refers to them
  status           String   @default("active") // active | paused | archived
  courseProgressPercent Int   @default(0)
  openTasksCount   Int      @default(0)
  blockedTasksCount Int     @default(0)
  lastBlock        String?
  nextAction       String?
  nextCallAt       DateTime?
  joinedAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt

  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  tasks           Task[]

  @@index([artistProfileId])
}

/// Tasks are the atomic unit of work between coaching sessions.
/// They can be linked to a course lesson (optional) so the user can always
/// trace an action back to the framework that produced it.
model Task {
  id              String   @id @default(cuid())
  courseId        String
  artistProfileId String
  managerArtistId String?  // optional: when created from manager view
  lessonSlug      String?
  title           String
  description     String?
  priority        String   @default("medium") // low | medium | high | urgent
  status          String   @default("todo") // todo | in_progress | done | blocked
  dueDate         DateTime?
  expectedOutput  String?
  coachPromptId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  artistProfile   ArtistProfile    @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  managerArtist   ManagerArtist?   @relation(fields: [managerArtistId], references: [id], onDelete: SetNull)

  @@index([artistProfileId])
  @@index([managerArtistId])
  @@index([courseId, lessonSlug])
  @@index([status])
}

/// Generated call-prep reports. Stored so the user can revisit the
/// pre-call snapshot they used last week and see the diff with this week.
model CallPrepReport {
  id              String   @id @default(cuid())
  courseId        String
  artistProfileId String
  callDate        DateTime?
  completedSince  String?  // markdown
  openTasks       String?  // markdown
  blocks          String?  // markdown
  questions       String?  // markdown
  decisions       String?  // markdown
  nextWeekPlan    String?  // markdown
  fullMarkdown    String?  // full report
  createdAt       DateTime @default(now())

  artistProfile ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@index([artistProfileId])
}

/// Coach conversation log — appended every time the user chats with the
/// coach. This is the "memory" the coach can recall between sessions.
///
/// `sessionId` groups user + assistant turns of one chat thread.
/// `role` discriminates the speaker: 'user' | 'assistant' | 'preset'.
///   - 'preset'   → legacy 13-button coach prompts (backward compat)
///   - 'user'     → free-form chat user message
///   - 'assistant' → free-form chat M3 reply
model CoachConversation {
  id              String   @id @default(cuid())
  artistProfileId String?
  promptId        String
  promptLabel     String
  userMessage     String?
  coachResponse   String
  sources         String?  // JSON array of file refs
  sessionId       String?
  role            String?  // 'user' | 'assistant' | 'preset'
  createdAt       DateTime @default(now())

  artistProfile ArtistProfile? @relation(fields: [artistProfileId], references: [id], onDelete: SetNull)

  @@index([artistProfileId])
  @@index([createdAt])
  @@index([sessionId])
}

// ===========================================================================
// Release Growth System — daily operating layer for artists and managers
// ===========================================================================

/// A single release (single, EP, album, videoclip, live, campaign).
/// Everything operational for the launch hangs off the Release:
/// milestones, content ideas, goals, metrics, outreach.
model Release {
  id              String    @id @default(cuid())
  artistProfileId String
  title           String
  type            String    @default("single") // single | ep | album | videoclip | live | campaign
  status          String    @default("planning") // planning | pre_release | released | post_release | archived
  releaseDate     DateTime?
  mainGoal        String?
  budget          Float?
  platforms       String?   // JSON array
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artistProfile ArtistProfile       @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  milestones    ReleaseMilestone[]
  contentIdeas  ContentIdea[]
  metrics       MetricSnapshot[]
  goals         Goal[]
  outreach      Outreach[]

  @@index([artistProfileId])
  @@index([status])
  @@index([releaseDate])
}

/// A milestone within a release (kickoff, single artwork, mixing, PR push,
/// release day, post-release review). Drives the kanban-style release view.
model ReleaseMilestone {
  id          String   @id @default(cuid())
  releaseId   String
  title       String
  description String?
  dueDate     DateTime?
  status      String   @default("todo") // todo | in_progress | done | blocked
  priority    String   @default("medium") // low | medium | high | urgent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId])
  @@index([status])
}

/// Content idea — calendar entries for reels, tiktoks, posts, lives.
/// Optionally tied to a release so the user can plan content per launch.
model ContentIdea {
  id              String    @id @default(cuid())
  artistProfileId String
  releaseId       String?
  platform        String    // instagram | tiktok | youtube | spotify | newsletter | website | other
  format          String    // reel | tiktok | carousel | story | short | post | email | live | other
  title           String
  hook            String?
  script          String?
  caption         String?
  cta             String?
  status          String    @default("idea") // idea | draft | approved | scheduled | published | archived
  publishAt       DateTime?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artistProfile ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  release       Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([artistProfileId])
  @@index([releaseId])
  @@index([status])
  @@index([publishAt])
}

/// Manual metrics snapshot for an artist on a given platform/date.
/// User enters follower/views/streams/linkClicks etc. manually — this is
/// a measurement tool, not a tracker.
model MetricSnapshot {
  id               String   @id @default(cuid())
  artistProfileId  String
  releaseId        String?
  platform         String
  date             DateTime
  followers        Int?
  views            Int?
  likes            Int?
  comments         Int?
  shares           Int?
  saves            Int?
  streams          Int?
  monthlyListeners Int?
  profileVisits    Int?
  linkClicks       Int?
  notes            String?
  createdAt        DateTime @default(now())

  artistProfile ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  release       Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([artistProfileId])
  @@index([releaseId])
  @@index([platform, date])
}

/// Mini CRM contact (curator, venue, press, influencer, label, artist, fan,
/// sponsor). Tied to an artist profile optionally so a manager can keep a
/// shared contact book.
model Contact {
  id              String   @id @default(cuid())
  artistProfileId String?
  name            String
  type            String   @default("other") // curator | venue | press | influencer | label | artist | fan | sponsor | other
  email           String?
  instagram       String?
  tiktok          String?
  website         String?
  city            String?
  notes           String?
  status          String   @default("new") // new | active | warm | cold | archived
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artistProfile ArtistProfile? @relation(fields: [artistProfileId], references: [id], onDelete: SetNull)
  outreach      Outreach[]

  @@index([artistProfileId])
  @@index([type])
  @@index([status])
}

/// An outreach attempt — DM, email, phone — towards a contact. Tracks
/// status and next-follow-up date so the user never forgets a follow-up.
model Outreach {
  id              String    @id @default(cuid())
  artistProfileId String
  releaseId       String?
  contactId       String
  channel         String    @default("email") // email | instagram | tiktok | whatsapp | phone | other
  status          String    @default("to_contact") // to_contact | contacted | replied | interested | rejected | closed
  message         String?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artistProfile ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  release       Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  contact       Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([artistProfileId])
  @@index([releaseId])
  @@index([contactId])
  @@index([status])
  @@index([nextFollowUpAt])
}

/// Measurable goal — e.g. "100 fan emails in 30 days". Tracks current vs
/// target value with deadline.
model Goal {
  id              String    @id @default(cuid())
  artistProfileId String
  releaseId       String?
  title           String
  metric          String    // e.g. "emails", "streams", "followers"
  targetValue     Float
  currentValue    Float     @default(0)
  deadline        DateTime?
  status          String    @default("active") // active | achieved | missed | archived
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artistProfile ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  release       Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([artistProfileId])
  @@index([releaseId])
  @@index([status])
}
